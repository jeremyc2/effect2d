{
	"name": "effect2d",
	"description": "Love2d Vibe-Fork in Effect TypeScript.",
	"version": "0.0.1",
	"type": "module",
	"private": true,
	"repository": {
		"type": "git",
		"url": "https://github.com/jeremyc2/effect2d.git"
	},
	"scripts": {
		"typecheck": "tsgo",
		"all": "bun typecheck && bun check && bun test && bun build:docs",
		"build:docs": "bun --bun scripts/build-doc-site.ts",
		"run:cavern": "bun --bun games/cavern/main.ts",
		"commentary": "bun --bun scripts/gameplay-commentary.ts",
		"commentary:cavern": "bun --bun commentary live --game Effect2d/cavern",
		"check:staged": "bun --bun biome check --write --staged && bun --bun oxlint -c .oxlintrc.jsonc",
		"check": "bun --bun biome check --write && bun --bun oxlint -c .oxlintrc.jsonc",
		"reference:update": "git submodule update --init --remote reference_repositories/effect-smol reference_repositories/love",
		"prepare": "effect-tsgo patch",
		"chore:update": "bun update --latest && bun add effect@beta @effect/platform-bun@beta"
	},
	"dependencies": {
		"@effect/platform-bun": "^4.0.0-beta.65",
		"effect": "^4.0.0-beta.65",
		"node-web-audio-api": "^1.0.9",
		"skia-canvas": "^3.0.8"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@effect/language-service": "^0.85.1",
		"@effect/tsgo": "^0.6.0",
		"@oxlint/plugins": "^1.64.0",
		"@types/bun": "1.3.13",
		"@typescript/native-preview": "^7.0.0-dev.20260511.1",
		"oxlint": "^1.64.0"
	},
	"trustedDependencies": [
		"msgpackr-extract",
		"skia-canvas"
	]
}
